<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="config_openai_api_key" model="ir.config_parameter">
            <field name="key">smart_delivery.openai_api_key</field>
            <field name="value"></field>
        </record>
        <record id="config_fcm_server_key" model="ir.config_parameter">
            <field name="key">smart_delivery.fcm_server_key</field>
            <field name="value"></field>
        </record>
        <record id="config_default_db" model="ir.config_parameter">
            <field name="key">smart_delivery.default_db</field>
            <field name="value">smart_delivery</field>
        </record>
    </data>

    <data>
        <record id="seq_smart_delivery_order" model="ir.sequence">
            <field name="name">Smart Delivery Order</field>
            <field name="code">smart.delivery.order</field>
            <field name="prefix">SDO</field>
            <field name="padding">5</field>
        </record>
    </data>
</odoo>
