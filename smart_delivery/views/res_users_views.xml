<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_form_smart_delivery" model="ir.ui.view">
        <field name="name">res.users.form.smart.delivery</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Smart Delivery" name="smart_delivery">
                    <group>
                        <field name="smart_delivery_role"/>
                        <field name="smart_driver_id"
                               invisible="smart_delivery_role != 'driver'"/>
                        <field name="smart_customer_phone"
                               invisible="smart_delivery_role != 'customer'"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
