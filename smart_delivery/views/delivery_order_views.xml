<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_smart_delivery_order_tree" model="ir.ui.view">
        <field name="name">smart.delivery.order.tree</field>
        <field name="model">smart.delivery.order</field>
        <field name="arch" type="xml">
            <tree string="Delivery Orders"
                  decoration-success="status == 'delivered'">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="driver_id"/>
                <field name="status" widget="badge"
                       decoration-info="status in ('created', 'assigned')"
                       decoration-warning="status in ('picked_up', 'in_transit')"
                       decoration-success="status == 'delivered'"/>
                <field name="rating" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_smart_delivery_order_form" model="ir.ui.view">
        <field name="name">smart.delivery.order.form</field>
        <field name="model">smart.delivery.order</field>
        <field name="arch" type="xml">
            <form string="Delivery Order">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="created,assigned,picked_up,in_transit,out_for_delivery,delivered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="customer_name"/>
                            <field name="customer_phone"/>
                            <field name="customer_user_id"/>
                        </group>
                        <group string="Driver">
                            <field name="driver_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Pickup Location">
                            <field name="pickup_address"/>
                            <field name="pickup_lat"/>
                            <field name="pickup_lng"/>
                        </group>
                        <group string="Delivery Location">
                            <field name="delivery_address"/>
                            <field name="delivery_lat"/>
                            <field name="delivery_lng"/>
                        </group>
                    </group>
                    <group>
                        <group string="Current Position">
                            <field name="current_lat"/>
                            <field name="current_lng"/>
                            <field name="last_speed"/>
                            <field name="last_movement_time"/>
                        </group>
                        <group string="Confirmation &amp; Rating">
                            <field name="confirmation_pin"/>
                            <field name="rating"/>
                            <field name="feedback"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="GPS Logs" name="gps_logs">
                            <field name="gps_log_ids">
                                <tree>
                                    <field name="timestamp"/>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                    <field name="speed"/>
                                    <field name="driver_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Proof of Delivery" name="pod">
                            <group>
                                <group string="Photo">
                                    <field name="pod_image" widget="image" nolabel="1"/>
                                </group>
                                <group string="Signature">
                                    <field name="pod_signature" widget="image" nolabel="1"/>
                                </group>
                            </group>
                            <group>
                                <field name="pod_timestamp"/>
                            </group>
                        </page>
                        <page string="Notifications" name="notifications">
                            <field name="notification_log" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_smart_delivery_order_graph" model="ir.ui.view">
        <field name="name">smart.delivery.order.graph</field>
        <field name="model">smart.delivery.order</field>
        <field name="arch" type="xml">
            <graph string="Delivery Analysis" type="bar" sample="1">
                <field name="status"/>
            </graph>
        </field>
    </record>

    <record id="view_smart_delivery_order_pivot" model="ir.ui.view">
        <field name="name">smart.delivery.order.pivot</field>
        <field name="model">smart.delivery.order</field>
        <field name="arch" type="xml">
            <pivot string="Delivery Statistics" sample="1">
                <field name="driver_id" type="row"/>
                <field name="status" type="col"/>
                <field name="rating" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_smart_delivery_order_search" model="ir.ui.view">
        <field name="name">smart.delivery.order.search</field>
        <field name="model">smart.delivery.order</field>
        <field name="arch" type="xml">
            <search string="Search Deliveries">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="driver_id"/>
                <separator/>
                <filter string="In Transit" name="in_transit" domain="[('status', '=', 'in_transit')]"/>
                <filter string="Delivered" name="delivered" domain="[('status', '=', 'delivered')]"/>
                <separator/>
                <filter string="Created Today" name="created_today"
                        domain="[('create_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0, 0, 0)))]"/>
                <filter string="Rated" name="rated" domain="[('rating', '&gt;', 0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Driver" name="group_driver" context="{'group_by': 'driver_id'}"/>
                    <filter string="Creation Date" name="group_create_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_smart_delivery_order" model="ir.actions.act_window">
        <field name="name">Delivery Orders</field>
        <field name="res_model">smart.delivery.order</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="search_view_id" ref="view_smart_delivery_order_search"/>
    </record>

    <record id="action_smart_delivery_dashboard" model="ir.actions.act_window">
        <field name="name">Delivery Statistics</field>
        <field name="res_model">smart.delivery.order</field>
        <field name="view_mode">graph,pivot</field>
        <field name="search_view_id" ref="view_smart_delivery_order_search"/>
        <field name="context">{'search_default_group_status': 1}</field>
    </record>

</odoo>
