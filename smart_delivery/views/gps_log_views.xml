<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_smart_gps_log_tree" model="ir.ui.view">
        <field name="name">smart.gps.log.tree</field>
        <field name="model">smart.gps.log</field>
        <field name="arch" type="xml">
            <tree string="GPS Logs" create="false">
                <field name="timestamp"/>
                <field name="driver_id"/>
                <field name="delivery_id"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="speed"/>
            </tree>
        </field>
    </record>

    <record id="action_smart_gps_log" model="ir.actions.act_window">
        <field name="name">GPS Logs</field>
        <field name="res_model">smart.gps.log</field>
        <field name="view_mode">tree</field>
    </record>

</odoo>
