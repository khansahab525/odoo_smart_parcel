<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_smart_delivery" model="ir.module.category">
            <field name="name">Smart Delivery</field>
            <field name="sequence">50</field>
        </record>

        <record id="group_smart_delivery_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_smart_delivery"/>
        </record>

        <record id="group_smart_delivery_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_smart_delivery"/>
            <field name="implied_ids" eval="[(4, ref('group_smart_delivery_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_smart_delivery_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_smart_delivery"/>
            <field name="implied_ids" eval="[(4, ref('group_smart_delivery_user'))]"/>
        </record>

        <record id="group_smart_delivery_customer" model="res.groups">
            <field name="name">Customer</field>
            <field name="category_id" ref="module_category_smart_delivery"/>
            <field name="implied_ids" eval="[(4, ref('group_smart_delivery_user'))]"/>
        </record>

    </data>
</odoo>
